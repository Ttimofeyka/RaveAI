import "../layers/linear"

void main {
    Linear layer = Linear(3, 3);

    // Example input and target
    std::vector<float> input = std::vector<float>([1f, 2f, 3f]);
    std::vector<float> target = std::vector<float>([0.5f, 1f, 1.5f]);

    // Training
    layer.train(input, target, 0.01f, 1000, 100);

    // Final output after training
    std::vector<float> output = layer.forward(input);
    std::println("Final output:");
    foreach(e; output) std::println(e);
}