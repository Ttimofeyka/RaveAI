import <std/io> <std/matrix> <std/math> <std/random>

// Mean Squared Error loss function and its derivative
float mseLoss(float* output, float* target, int size) {
    float loss = 0f;
    for(int i=0; i<size; i++) {
        float error = output[i] - target[i];
        loss += (error * error);
    }
} => loss / size;

void mseLossD(float* output, float* target, float* doutput, int size) {
    for(int i=0; i<size; i++) doutput[i] = 2 * (output[i] - target[i]) / size;
}